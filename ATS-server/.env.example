# Server
PORT=5000
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_NAME=ats.sid
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Slack (optional)
SLACK_WEBHOOK_URL=

# Read.ai (optional)
READAI_API_KEY=
READAI_WEBHOOK_SECRET=


# Scheduling
WORK_DAY_START_HOUR=9
WORK_DAY_END_HOUR=18
FREE_SLOT_INCREMENT_MINUTES=30
FREE_SLOT_BUFFER_MINUTES=30
DEFAULT_INTERVIEW_DURATION_MINUTES=45

# Background jobs
TRANSCRIPT_JOB_CRON=*/15 * * * *
TRANSCRIPT_FETCH_LOOKBACK_HOURS=24
TRANSCRIPT_FETCH_DELAY_MINUTES=30

# Sync
SYNC_BATCH_SIZE=5
SYNC_BATCH_DELAY_MS=500
INVITE_EXPIRY_DAYS=7


#Add this Priya

# Groq AI notes (optional)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b